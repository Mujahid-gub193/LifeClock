PORT=3000

# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=lifeclock
DB_USER=postgres
DB_PASS=your_postgres_password

# Or use a full connection URL (overrides individual fields above)
# DATABASE_URL=postgresql://postgres:password@localhost:5432/lifeclock
DB_SSL=false

JWT_SECRET=lifeclock-super-secret-key-change-this

# Optional: Gmail for study session email reminders
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-gmail-app-password

CLIENT_URL=http://localhost:3000
APP_URL=http://localhost:3000
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
